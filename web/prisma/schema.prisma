generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum OrderStatus {
  CALCULATING
  CALCULATION_FAILED
  AWAITING_PAYMENT
  PAID
  PRINTING
  PRINTED
  FAILED
}

enum OrderBatchStatus {
  COLLECTING
  AWAITING_PAYMENT
  PAID
  COMPLETED
  PARTIALLY_FAILED
  CANCELLED
}

enum PaymentMethod {
  SBP_TRANSFER
  ON_SITE
  TBANK_SBP
  TBANK_ONLINE
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
  REFUNDED
}

enum MessengerPlatform {
  telegram
  max
}

enum BindTokenPurpose {
  staff
  agent
}

model User {
  id         String       @id @default(cuid())
  telegramId BigInt?      @unique
  maxUserId  BigInt?      @unique
  username   String?
  firstName  String?
  createdAt  DateTime     @default(now())
  orders     Order[]
  batches    OrderBatch[]
}

model Point {
  id                     String           @id @default(cuid())
  slug                   String           @unique
  name                   String
  isActive               Boolean          @default(true)
  pricePerPageKopeks     Int              @default(1000)
  paymentMethodsEnabled  PaymentMethod[]
  transferPhone          String?
  transferBankLabel      String?
  lastSeenAt             DateTime?
  createdAt              DateTime         @default(now())
  orders                 Order[]
  batches                OrderBatch[]
  staffChannels          StaffChannel[]
  bindTokens             BindToken[]
}

model StaffChannel {
  id        String             @id @default(cuid())
  pointId   String
  point     Point              @relation(fields: [pointId], references: [id], onDelete: Cascade)
  platform  MessengerPlatform
  chatId    BigInt?
  userId    BigInt?
  label     String?
  isActive  Boolean            @default(true)
  boundAt   DateTime           @default(now())

  @@unique([pointId, platform, chatId])
  @@unique([pointId, platform, userId])
  @@index([pointId, isActive])
}

model BindToken {
  token     String           @id
  pointId   String
  point     Point            @relation(fields: [pointId], references: [id], onDelete: Cascade)
  purpose   BindTokenPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([pointId, purpose])
}

model OrderBatch {
  id                String           @id @default(cuid())
  status            OrderBatchStatus @default(COLLECTING)
  userId            String
  user              User             @relation(fields: [userId], references: [id])
  pointId           String
  point             Point            @relation(fields: [pointId], references: [id])
  totalPages        Int              @default(0)
  totalAmountKopeks Int              @default(0)
  paymentMethod     PaymentMethod?
  paymentMethodAt   DateTime?
  paymentClaimedAt  DateTime?
  paidAt            DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  orders            Order[]
  payments          Payment[]

  @@index([status, pointId, createdAt])
}

model Order {
  id                 String      @id @default(cuid())
  status             OrderStatus @default(AWAITING_PAYMENT)
  fileName           String
  filePath           String
  mimeType           String?
  pageCount          Int         @default(1)
  amountKopeks       Int         @default(0)
  calculatedAt       DateTime?
  paymentConfirmedAt DateTime?
  paymentMethod      PaymentMethod?
  paymentMethodAt    DateTime?
  paymentClaimedAt   DateTime?
  userId             String
  user               User        @relation(fields: [userId], references: [id])
  pointId            String
  point              Point       @relation(fields: [pointId], references: [id])
  batchId            String?
  batch              OrderBatch? @relation(fields: [batchId], references: [id])
  batchIndex         Int?
  clientMessageId    String?
  clientMessageChatId String?
  paidAt             DateTime?
  printedAt          DateTime?
  printAttemptCount  Int         @default(0)
  errorMessage       String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  payments           Payment[]

  @@index([status, pointId])
  @@index([createdAt])
  @@index([batchId, batchIndex])
}

model Payment {
  id              String        @id @default(cuid())
  batchId         String?
  batch           OrderBatch?   @relation(fields: [batchId], references: [id], onDelete: SetNull)
  orderId         String?
  order           Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  merchantOrderId String        @unique
  externalId      String?
  amountKopeks    Int
  status          PaymentStatus @default(PENDING)
  qrPayload       String?
  confirmedAt     DateTime?
  createdAt       DateTime      @default(now())

  @@index([batchId])
  @@index([externalId])
}
