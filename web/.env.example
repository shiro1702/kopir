# Neon → Dashboard → Connection string (pooled, ssl)
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.neon.tech/kopir?sslmode=require"
# Direct connection for Prisma migrations (no pgbouncer)
DATABASE_URL_UNPOOLED="postgresql://user:pass@ep-xxx.neon.tech/kopir?sslmode=require"

# Vercel → Storage → Blob → Connect to Project
# Vercel adds these two when store is connected:
BLOB_STORE_ID="store_..."
BLOB_WEBHOOK_PUBLIC_KEY="..."   # only for presigned browser uploads (bot/agent do not use it yet)
# OIDC auth is automatic on Vercel (not shown in env list). Locally: vercel env pull .env.local

TELEGRAM_BOT_TOKEN="..."
TELEGRAM_BOT_USERNAME=""   # without @, for bind deep links
MAX_BOT_TOKEN="..."
MAX_WEBHOOK_SECRET="..."
ADMIN_SECRET="..."
AGENT_API_KEY="..."

# Sprint 0.1 — DOCX pricing
PRICE_PER_PAGE_KOPEKS=1000
CALCULATION_TIMEOUT_SEC=300

# Sprint 0.2 — batch orders
BATCH_MAX_FILES=5
BATCH_BUILD_TIMEOUT_MIN=15

# terminal = оплата на терминале, сотрудник подтверждает в TG/админке
# online = будущая оплата в боте (Sprint 2+)
PAYMENT_MODE=terminal
POINT_TRANSFER_PHONE=""
POINT_TRANSFER_BANK_LABEL=""
PAYMENT_METHODS_ENABLED=SBP_TRANSFER,TBANK_SBP,TBANK_ONLINE,ON_SITE
POINT_OFFLINE_THRESHOLD_SEC=20
STAFF_TELEGRAM_CHAT_ID=""   # chat id сотрудника в Telegram
STAFF_MAX_USER_ID=""         # user_id сотрудника в MAX

# Sprint 3 — T-Bank internet acquiring (SBP)
TBANK_TERMINAL_KEY=""
TBANK_PASSWORD=""
TBANK_API_URL="https://securepay.tinkoff.ru/v2"
TBANK_NOTIFICATION_URL=""
TBANK_WEBHOOK_SECRET=""
# Т-Чеки (ФФД 1.05): prod terminal = true, test DEMO = false
TBANK_RECEIPT_ENABLED=false
TBANK_RECEIPT_EMAIL=""
# Defaults match УСН 6% / без НДС / услуга / полный расчёт
TBANK_RECEIPT_TAXATION=usn_income
TBANK_RECEIPT_TAX=none
TBANK_RECEIPT_PAYMENT_OBJECT=service
TBANK_RECEIPT_PAYMENT_METHOD=full_payment
TBANK_RECEIPT_ITEM_NAME="Услуги копировального центра"
# Optional: Russian Trusted CA for T-Bank API (also bundled in web/certs/)
# NODE_EXTRA_CA_CERTS="./certs/russian-trusted-ca-bundle.pem"
NUXT_PUBLIC_SITE_URL=""

# Optional: public URL for set-webhook (Vercel sets VERCEL_URL automatically)
# NUXT_PUBLIC_SITE_URL="https://kopir-xxx.vercel.app"

# Подробнее: doc/dev/DEPLOY.md, doc/dev/ENV_SETUP.md
