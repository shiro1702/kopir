# Neon → Dashboard → Connection string (pooled, ssl)
DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/kopir?sslmode=require"

# Vercel → Storage → Blob → Connect to Project (private store)
# On Vercel: BLOB_STORE_ID + VERCEL_OIDC_TOKEN are added automatically when store is connected.
# Locally: run `vercel env pull .env.local` (OIDC token is short-lived, refresh when expired).
BLOB_STORE_ID="store_..."
# BLOB_WEBHOOK_PUBLIC_KEY="..."  # only for presigned browser uploads (not used by bot/agent yet)

TELEGRAM_BOT_TOKEN="..."
MAX_BOT_TOKEN="..."
MAX_WEBHOOK_SECRET="..."
ADMIN_SECRET="..."
AGENT_API_KEY="..."

# Sprint 0.1 — DOCX pricing
PRICE_PER_PAGE_KOPEKS=1000
CALCULATION_TIMEOUT_SEC=120

# Sprint 0.2 — batch orders
BATCH_MAX_FILES=5
BATCH_BUILD_TIMEOUT_MIN=15

# terminal = оплата на терминале, сотрудник подтверждает в TG/админке
# online = будущая оплата в боте (Sprint 2+)
PAYMENT_MODE=terminal
STAFF_TELEGRAM_CHAT_ID=""   # chat id сотрудника в Telegram
STAFF_MAX_USER_ID=""         # user_id сотрудника в MAX

# Optional: public URL for set-webhook (Vercel sets VERCEL_URL automatically)
# NUXT_PUBLIC_SITE_URL="https://kopir-xxx.vercel.app"

# Подробнее: doc/dev/DEPLOY.md, doc/dev/ENV_SETUP.md
